# Aegis SRE - Environment Configuration

# 1. LLM endpoint (OpenAI-compatible; e.g. local Ollama)
# Aegis talks to models over the OpenAI Chat Completions API. A local Ollama
# instance exposes this at /v1 — fully on-prem / air-gapped, no SaaS egress.
#   ollama serve
#   ollama pull hermes3:8b
#   ollama pull qwen2.5-coder:7b
AEGIS_LLM_BASE_URL="http://localhost:11434/v1"
AEGIS_LLM_API_KEY="ollama"          # dummy key; local endpoint needs no auth
AEGIS_EXECUTOR_MODEL="hermes3:8b"   # reasoning/patch model
AEGIS_REVIEWER_MODEL="qwen2.5-coder:7b"  # security/validation model
AEGIS_LLM_TIMEOUT="90"              # seconds per LLM call

# 2. E2B Sandbox API Key
# Get this from https://e2b.dev/docs/getting-started/api-key
E2B_API_KEY="your_e2b_api_key_here"

# 3. GitOps PR Configuration
# When VCS_PROVIDER=github, an approved patch ships via the clone-based GitOps
# flow (clone -> branch -> apply patch -> commit -> push -> open PR).
# Use a FINE-GRAINED PAT scoped to VCS_REPO_URL with:
#   Repository permissions -> Contents: Read and write
#   Repository permissions -> Pull requests: Read and write
# Create at GitHub -> Settings -> Developer settings -> Fine-grained tokens.
# VCS_PROVIDER can be 'github', 'gitlab', or 'local'.
VCS_PROVIDER=local
VCS_REPO_URL=your_org/your_repo
GITHUB_TOKEN=your_github_token_here
GITLAB_TOKEN=your_gitlab_token_here

# Sandbox Provider Configuration
# SANDBOX_PROVIDER can be 'e2b' or 'local'
SANDBOX_PROVIDER=local

# 4. Model selection is configured in section 1 above (AEGIS_EXECUTOR_MODEL /
# AEGIS_REVIEWER_MODEL). To use a hosted OpenAI-compatible provider instead of
# local Ollama, point AEGIS_LLM_BASE_URL at it and set AEGIS_LLM_API_KEY.
