# Aegis SRE - Environment Configuration

# 1. LLM endpoint (OpenAI-compatible; e.g. local Ollama)
# Aegis talks to models over the OpenAI Chat Completions API. A local Ollama
# instance exposes this at /v1 — fully on-prem / air-gapped, no SaaS egress.
#   ollama serve
#   ollama pull hermes3:8b
#   ollama pull qwen2.5-coder:7b
AEGIS_LLM_BASE_URL="http://localhost:11434/v1"
AEGIS_LLM_API_KEY="ollama"          # dummy key; local endpoint needs no auth
AEGIS_EXECUTOR_MODEL="hermes3:8b"   # reasoning/patch model
AEGIS_REVIEWER_MODEL="qwen2.5-coder:7b"  # security/validation model
AEGIS_LLM_TIMEOUT="90"              # seconds per LLM call

# 2. E2B Sandbox API Key
# Get this from https://e2b.dev/docs/getting-started/api-key
E2B_API_KEY="your_e2b_api_key_here"

# 2b. Observability source (Prometheus HTTP API base; no trailing /api/v1).
# The researcher node runs PromQL here to enrich diagnosis with live metrics.
# Leave empty to disable live-metrics enrichment.
PROMETHEUS_URL=http://localhost:9090

# 2c. Incident alerting sink. Aegis POSTs PagerDuty Events v2-shaped
# trigger/acknowledge/resolve events here. Use a real PagerDuty Events v2
# endpoint in production, or a webhook catcher (webhook.site) for testing.
# Leave empty to disable external alerting.
ALERT_WEBHOOK_URL=
ALERT_ROUTING_KEY=aegis-mock-routing-key

# 3. GitOps PR Configuration
# When VCS_PROVIDER=github, an approved patch ships via the clone-based GitOps
# flow (clone -> branch -> apply patch -> commit -> push -> open PR).
# Use a FINE-GRAINED PAT scoped to VCS_REPO_URL with:
#   Repository permissions -> Contents: Read and write
#   Repository permissions -> Pull requests: Read and write
# Create at GitHub -> Settings -> Developer settings -> Fine-grained tokens.
# VCS_PROVIDER can be 'github', 'gitlab', or 'local'.
VCS_PROVIDER=local
VCS_REPO_URL=your_org/your_repo
GITHUB_TOKEN=your_github_token_here
GITLAB_TOKEN=your_gitlab_token_here

# Sandbox Provider Configuration (Batch 5 / S3 — isolated-by-default).
# The repro step EXECUTES attacker-influenceable patched code, so prefer real
# isolation. SANDBOX_PROVIDER: 'e2b' | 'container' (Docker) | 'local'. Leave unset
# to auto-select: E2B (if E2B_API_KEY) -> Docker container (if available) -> local.
SANDBOX_PROVIDER=
# Refuse to validate on the bare host: with AEGIS_REQUIRE_SANDBOX=true the gate
# fails closed unless an isolated sandbox (E2B/container) is available. Set true
# in production.
AEGIS_REQUIRE_SANDBOX=false
# Container isolation limits (provider=container): cgroup caps + image overrides.
AEGIS_SANDBOX_DOCKER_MEM=512m
AEGIS_SANDBOX_DOCKER_CPUS=1.0
AEGIS_SANDBOX_DOCKER_PIDS=128
# AEGIS_SANDBOX_IMAGE=python:3.12-slim
# Local-engine resource caps (cgroup-lite via POSIX rlimits): CPU seconds + max
# file size are on by default; memory (RLIMIT_AS) and process count (RLIMIT_NPROC)
# are opt-in (0 = off) because they belong to containers.
AEGIS_SANDBOX_CPU_SECONDS=60
AEGIS_SANDBOX_FSIZE_MB=64
AEGIS_SANDBOX_MEM_MB=0
AEGIS_SANDBOX_NPROC=0

# 4. Model selection is configured in section 1 above (AEGIS_EXECUTOR_MODEL /
# AEGIS_REVIEWER_MODEL). To use a hosted OpenAI-compatible provider instead of
# local Ollama, point AEGIS_LLM_BASE_URL at it and set AEGIS_LLM_API_KEY.

# 5. Security / hardening (red-team batches).
# Auth + RBAC: per-identity API keys "key:name:role" (role: ingest|approver|admin).
# Approving/rejecting remediations requires the 'approver' role. Empty => falls
# back to AEGIS_WEBHOOK_TOKEN (single admin key) / open (dev).
AEGIS_API_KEYS=
AEGIS_WEBHOOK_TOKEN=
AEGIS_SENTRY_SECRET=
# Data-plane integrity (Batch 4): HMAC key for signing approval blobs in the
# Redis approval store. REQUIRED for the Redis/cloud tier (startup fails closed
# without it). Empty => falls back to AEGIS_WEBHOOK_TOKEN. Use a strong random
# value, and prefer rediss:// + a Redis password for AUTH/TLS.
AEGIS_APPROVAL_SECRET=
# Abuse controls: only trust X-Forwarded-For behind a known proxy.
AEGIS_TRUST_XFF=false
AEGIS_MAX_BODY_BYTES=1000000
AEGIS_MAX_CRASH_LOG=65536
AEGIS_MAX_WS=200
