# ==========================================
# AEGIS SRE - Global Configuration
# ==========================================

# 1. The Brain (LLM Provider)
# LiteLLM routes this automatically. If you want to use Anthropic or local Ollama, update this.
OPENAI_API_KEY=your_openai_api_key_here

# 2. The Hands (Execution Sandbox)
# Required for spinning up secure cloud environments to compile and test the AI's code.
# Get an API key from https://e2b.dev
E2B_API_KEY=your_e2b_api_key_here

# 3. The Eyes (VCS & GitOps)
# Required for Aegis to fetch code context and open Pull Requests.
VCS_PROVIDER=github
VCS_REPO_URL=your-org/your-repo
GITHUB_TOKEN=your_github_personal_access_token_here
